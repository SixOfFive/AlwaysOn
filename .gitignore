# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual envs
.venv/
venv/
env/

# IDE / editor
.vscode/
.idea/
.claude/
*.swp
*.swo

# Local config / secrets
# jarvis.toml holds personal IPs, paths, MAC addresses, etc. The
# committed jarvis.example.toml is the schema/template.
jarvis.toml
*.local.toml
.env
.env.*
!.env.example

# Personal scratch / context dumps — never commit. braindump_ao.md is
# the working-state file the assistant reads after compaction; full of
# IPs, project names, debugging history. Move other such notes into
# private/ to keep them safely out of the index.
braindump_ao.md
private/

# Per-host model banlist (Ollama tags the catalog picker should skip).
# Auto-populated when a chat call times out — its content depends on
# the local GPU/VRAM and shouldn't ship with the repo.
model-banlist.txt

# Model weights and audio scratch
models/
*.bin
*.onnx
*.ppn
*.gguf
recordings/
*.wav

# Bundled assets we DO want in the repo
!android/app/src/main/assets/*.onnx

# Logs
*.log
logs/

# Android Studio / Gradle
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/app/.cxx/
android/captures/
android/local.properties
android/.cxx/
*.iml
*.apk
*.aab

# OS junk
Thumbs.db
.DS_Store
desktop.ini
